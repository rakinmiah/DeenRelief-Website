# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# local-only backups of large assets (e.g. pre-compression video originals)
*.original.*

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local media working folder — source assets for imports, not served by Next.
# Files are copied into /public/ when needed and committed there instead.
/DeenReliefMedia/

# Shop initiative — post-launch Shopify Headless work. Untracked until we're
# ready to integrate. To commit later: remove these lines, then `git add`.
/shop-draft/
/SHOP-PLAN.md
