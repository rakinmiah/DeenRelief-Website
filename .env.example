# ─── Resend ─────────────────────────────────────────────────────────────────
# API key for form + donation receipt emails (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address to receive form submissions (defaults to info@deenrelief.org)
CONTACT_EMAIL=info@deenrelief.org

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx                    # server-only, never expose
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx   # safe in client bundle
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx                  # signing secret for /api/stripe/webhook

# ─── Supabase ───────────────────────────────────────────────────────────────
# Get from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxx                 # server-only, never expose

# ─── App secrets ────────────────────────────────────────────────────────────
# Signing secret for magic links (donor self-service "manage" links in the
# monthly receipt email). Generate with `openssl rand -hex 32`. NEVER rotate
# casually — every active donor's manage link stops working until they get
# their next monthly receipt.
APP_SECRET=your-long-random-app-secret

# The canonical public URL of the site. Used to build absolute links in
# emails. Must match the deployed domain (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://deenrelief.org

# ─── Admin + cron ───────────────────────────────────────────────────────────
# Bearer token for protected admin endpoints (e.g. /api/admin/export-gift-aid).
# Generate a long random string: `openssl rand -hex 32`
ADMIN_API_TOKEN=your-long-random-admin-token

# Vercel Cron signs scheduled invocations with this. Same generation:
# `openssl rand -hex 32`. Add to Vercel Environment Variables too.
CRON_SECRET=your-long-random-cron-token

# ─── Upstash Redis (API rate limiting) ──────────────────────────────────────
# Free tier at https://console.upstash.com/ — create a Redis database,
# copy the REST URL + REST Token from its "Details" page.
# Leave unset to disable rate limiting (safe for dev).
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxx

# ─── Swiftaid (Gift Aid claim submission) ───────────────────────────────────
# Get from https://www.swiftaid.co.uk/ once your charity is registered.
# Leave unset to disable Swiftaid — the cron will log "skipped" and do nothing.
SWIFTAID_API_KEY=sa_xxxxxxxxxxxx
SWIFTAID_API_URL=https://api.swiftaid.co.uk/v1

# ─── Google Analytics 4 ─────────────────────────────────────────────────────
# GA4 Measurement ID (starts with "G-"). Leave empty pre-launch so the
# Next.js site doesn't cross-contaminate the live WordPress property's
# data. At DNS cutover, create a NEW GA4 property for the new site, paste
# the ID here, redeploy, and tracking turns on.
#
# Consent Mode v2 defaults-denied ship regardless of whether this is set —
# when empty, no gtag script is loaded and no data leaves the browser.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# ─── Google Ads Offline Conversion Import ──────────────────────────────────
# Powers /api/cron/google-ads-oci — uploads succeeded donations to Google
# Ads so Smart Bidding trains on real revenue (not gross click intent).
# Leave all unset to disable — the cron logs "skipped" and does nothing.
#
# Prereq: Google Ads API developer token (apply at
# https://developers.google.com/google-ads/api/docs/first-call/dev-token,
# review takes 1–3 weeks). Also needs a charity-vetted Google Ads account
# and an offline "Donation" conversion action created in the UI.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=                 # 10-digit account id, no dashes
GOOGLE_ADS_LOGIN_CUSTOMER_ID=           # MCC manager id if under one (optional)
GOOGLE_ADS_CONVERSION_ACTION_ID=        # numeric id of the Donation conversion action

# OAuth for the Google Ads API. Generate via Google Cloud Console →
# OAuth 2.0 Client IDs → Desktop app, then obtain a refresh token by
# running an OAuth flow once against the Ads scope:
# https://www.googleapis.com/auth/adwords
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# ─── Sentry (error monitoring) ──────────────────────────────────────────────
# Create a project at https://sentry.io, pick "Next.js". Copy the DSN from
# Project Settings → Client Keys (DSN).
# Leave unset to disable Sentry — safe no-op. Errors only log to Vercel.
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX

# Optional: for source-map uploads during build (so stack traces show
# original TypeScript, not minified). Get from Sentry → Settings → Auth
# Tokens → Create New. Needs project:write scope.
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxx
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# ─── Site password (preview protection) ─────────────────────────────────────
# Remove or leave empty to disable
SITE_PASSWORD=your-preview-password

# ─── Bazaar pre-launch feature flag ─────────────────────────────────────────
# Customer-facing /bazaar/* routes return 404 unless this is set to "true".
# Admin bazaar routes (/admin/bazaar/*) are NOT gated — they stay functional
# so trustees can keep working with the schema while the storefront is dark.
#
# Set to "true" on Vercel (Production environment) to launch the shop. The
# /api/bazaar/* endpoints honour the same flag as defense-in-depth, and the
# cross-link from /contact to /bazaar/contact only renders when this is on.
#
# Leave unset (or set to anything other than "true") to keep the shop hidden.
NEXT_PUBLIC_BAZAAR_ENABLED=

# ─── Royal Mail Click & Drop Order API (free tier) ──────────────────────────
# For pushing bazaar orders directly into Click & Drop from the admin so
# trustees don't retype shipping addresses. The trustee still logs into C&D
# to generate the actual label PDF — that's the paid Shipping API V4.
#
# Generate the key in your Click & Drop dashboard:
#   Settings → Integrations → API access → Generate
#
# Use the sandbox key on Preview and the production key on Production.
ROYAL_MAIL_API_KEY=

# Toggle for Click & Drop test mode. Royal Mail doesn't expose a
# test-mode switch in the dashboard UI — per their docs it's configured
# via the API. Setting this to "true" currently adds `testOrder: true`
# to each pushed order; if the docs say a different mechanism (a
# configuration-API call, a per-key distinction, or a different field
# name), src/lib/royal-mail-api.ts is the one place to adjust.
ROYAL_MAIL_API_TEST_MODE=

# Override only if Royal Mail rotates their endpoint host. Default is
# https://api.parcel.royalmail.com which is the current Order API base.
ROYAL_MAIL_API_BASE_URL=

# Sender details that the Order API actually accepts. The v1 spec's
# SenderDetailsRequest only has tradingName / phoneNumber / emailAddress —
# the return address is configured per-account in the C&D dashboard
# (Settings → Trading Addresses), NOT per-order via the API.
ROYAL_MAIL_SENDER_COMPANY=
ROYAL_MAIL_SENDER_EMAIL=
ROYAL_MAIL_SENDER_PHONE=

# Default package format for outgoing parcels. Valid enum values from the
# spec: undefined, letter, largeLetter, smallParcel, mediumParcel,
# largeParcel, parcel, documents. Most clothing/textile orders fit
# smallParcel; override if your typical parcel is bigger.
ROYAL_MAIL_PACKAGE_FORMAT=

# C&D service codes — pull from C&D Settings → Services. These are the
# defaults that ship in the code; override only if your account uses
# different codes.
ROYAL_MAIL_SERVICE_CODE_TRACKED_48=
ROYAL_MAIL_SERVICE_CODE_TRACKED_24=
ROYAL_MAIL_SERVICE_CODE_SPECIAL=
