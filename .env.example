# ─── Resend ─────────────────────────────────────────────────────────────────
# API key for form + donation receipt emails (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address to receive form submissions (defaults to info@deenrelief.org)
CONTACT_EMAIL=info@deenrelief.org

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx                    # server-only, never expose
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx   # safe in client bundle
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx                  # signing secret for /api/stripe/webhook

# ─── Supabase ───────────────────────────────────────────────────────────────
# Get from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxx                 # server-only, never expose

# ─── Admin + cron ───────────────────────────────────────────────────────────
# Bearer token for protected admin endpoints (e.g. /api/admin/export-gift-aid).
# Generate a long random string: `openssl rand -hex 32`
ADMIN_API_TOKEN=your-long-random-admin-token

# Vercel Cron signs scheduled invocations with this. Same generation:
# `openssl rand -hex 32`. Add to Vercel Environment Variables too.
CRON_SECRET=your-long-random-cron-token

# ─── Swiftaid (Gift Aid claim submission) ───────────────────────────────────
# Get from https://www.swiftaid.co.uk/ once your charity is registered.
# Leave unset to disable Swiftaid — the cron will log "skipped" and do nothing.
SWIFTAID_API_KEY=sa_xxxxxxxxxxxx
SWIFTAID_API_URL=https://api.swiftaid.co.uk/v1

# ─── Site password (preview protection) ─────────────────────────────────────
# Remove or leave empty to disable
SITE_PASSWORD=your-preview-password
